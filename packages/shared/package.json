      "default": "./dist/safety.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node dist/safety.test.js"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
