{
  "name": "@harmeese/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/types.js",
  "types": "dist/types.d.ts",
  "exports": {
    "./types.js": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./env.js": {
      "types": "./dist/env.d.ts",
      "default": "./dist/env.js"
    },
